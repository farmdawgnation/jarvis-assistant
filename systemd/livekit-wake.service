[Unit]
Description=LiveKit Wake Word Listener
After=livekit-agent.service sound.target

[Service]
User=pi
WorkingDirectory=/home/pi/pi-voice-agent/agent
EnvironmentFile=/home/pi/pi-voice-agent/.env
ExecStart=/home/pi/pi-voice-agent/.venv/bin/python main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
