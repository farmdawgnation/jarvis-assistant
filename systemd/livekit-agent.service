[Unit]
Description=LiveKit Voice Agent Worker
After=network.target docker.service
Requires=docker.service

[Service]
User=pi
WorkingDirectory=/home/pi/jarvis-assistant/agent
EnvironmentFile=/home/pi/jarvis-assistant/.env
ExecStart=/home/pi/jarvis-assistant/.venv/bin/python agent.py start
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
